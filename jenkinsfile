pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/my-html-project.git'
            }
        }

        stage('Build') {
            steps {
                sh 'docker build -t nagajothidocker/devops-app:1.0 .'
            }
        }

        stage('Push') {
            steps {
                sh 'docker push nagajothidocker/devops-app:1.0'
            }
        }
    }
}
